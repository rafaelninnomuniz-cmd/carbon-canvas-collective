# Hostinger / Apache — SPA + prerendered HTML fallback
RewriteEngine On

# Serve existing files / folders directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Try a prerendered route (e.g. /sobre -> /sobre/index.html)
RewriteCond %{DOCUMENT_ROOT}/%{REQUEST_URI}/index.html -f
RewriteRule ^(.*)$ /$1/index.html [L]

# Otherwise fall back to SPA shell
RewriteRule ^ /index.html [L]

# Long cache for hashed assets
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|jpg|jpeg|png|webp|svg|woff2?)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
